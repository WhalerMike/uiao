flowchart LR
    UR["👤 User Request"]
    AUTH["🔐 Authentication\n(Identity Plane)"]
    PE["📋 Policy Engine\n(OPA / Cedar)"]
    SM["🔀 Service Mesh\n(Envoy / Istio)"]
    BE["⚙️ Backend Services"]
    TC["📊 Telemetry Collection\n(SIEM / Sentinel)"]

    UR -->|"HTTPS"| AUTH
    AUTH -->|"JWT / SAML"| PE
    PE -->|"Permit / Deny"| SM
    SM -->|"mTLS"| BE
    BE -->|"Logs / Metrics"| TC
    TC -->|"Alerts"| AUTH
