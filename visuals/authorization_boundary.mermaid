flowchart LR
    EU["👤 External Users"]
    CDN["🛡️ CDN / WAF\n(DDoS / TLS termination)"]
    GW["🔀 UIAO Gateway\n(API Gateway / Load Balancer)"]

    subgraph AuthBoundary["Authorization Boundary"]
        direction TB
        IDP["🔐 Identity Plane\n(Okta / CyberArk)"]
        SVC["⚙️ Internal Services\n(Microservices / APIs)"]
        DS["🗄️ Data Stores\n(Encrypted at rest)"]
        IDP -->|"Authorize"| SVC
        SVC -->|"Queries"| DS
    end

    EU --> CDN
    CDN --> GW
    GW -->|"Authenticate"| IDP
