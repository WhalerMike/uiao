flowchart TD
    L7["🏛️ L7 – Governance & Compliance Plane\n(FedRAMP / NIST / FISMA)"]
    L6["⚙️ L6 – Management Plane\n(Policy / Orchestration / Config)"]
    L5["📊 L5 – Telemetry Plane\n(SIEM / Monitoring / Alerts)"]
    L4["🔐 L4 – Identity Plane\n(AuthN / AuthZ / Zero-Trust)"]
    L3["🌐 L3 – Overlay Plane\n(Network Fabric / SD-WAN / VPN)"]
    L2["📍 L2 – Addressing Plane\n(DNS / Service Discovery)"]
    L1["🖥️ L1 – Infrastructure Plane\n(Compute / Storage / Network HW)"]

    L7 -->|"Policies"| L6
    L6 -->|"Config Push"| L5
    L6 -->|"Config Push"| L4
    L6 -->|"Config Push"| L3
    L6 -->|"Config Push"| L2
    L6 -->|"Config Push"| L1
    L4 -->|"Token Enforcement"| L3
    L2 -->|"Route to"| L1
    L3 -->|"Encapsulates"| L1
    L5 -->|"Feedback Loop"| L6
