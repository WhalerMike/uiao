flowchart LR
    CY["📄 Canon YAML\n(Single Source of Truth)"]
    J2["📝 Jinja2 Templates\n(templates/*.j2)"]
    MD["📋 Markdown Docs\n(docs/*.md)"]
    MK["🌐 MkDocs HTML\n(GitHub Pages)"]
    MER["🔷 Mermaid Diagrams\n(visuals/*.mermaid)"]
    PNG["🖼️ PNG Images\n(assets/images/mermaid/)"]
    EXP["📦 Exports\n(DOCX / PPTX / OSCAL)"]

    CY -->|"render_template()"| J2
    J2 -->|"build_docs()"| MD
    MD -->|"mkdocs build"| MK
    CY -->|"generate_diagrams_from_canon()"| MER
    MER -->|"render_mermaid_file()"| PNG
    PNG -->|"embed"| EXP
    MD -->|"build_rich_docx()"| EXP
