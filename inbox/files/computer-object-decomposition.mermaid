---
title: "AD Computer Object Decomposition"
id: DIAG-GAE-001
canon_ref: ADR-031
---

%%{init: {"theme": "neutral"}}%%
flowchart TD
    ADC["<b>AD Computer Object</b><br/>Desktop / Laptop / Server"]

    ADC --> IP["<b>Identity Plane</b>"]
    ADC --> WP["<b>Workload Plane</b>"]
    ADC --> MP["<b>Management Plane</b>"]

    IP --> ED["Entra Device<br/><i>Joined / Registered / Hybrid</i>"]
    IP --> IP_note["PRT anchor<br/>Conditional Access<br/>Intune scope"]

    WP --> WI["Service Principal<br/>Managed Identity<br/>Workload Identity"]
    WP --> WP_note["Replaces SPNs<br/>Kerberos → OAuth2/OIDC<br/>Machine auth → App tokens"]

    MP --> MC["<b>Clients</b><br/>Microsoft Intune"]
    MP --> MS["<b>Servers</b><br/>Azure Arc<br/><i>ARM resource — not Entra</i>"]

    ED --> OP["OrgPath on device object<br/>→ Dynamic group membership<br/>→ Intune policy scope"]
    WI --> AP["App Registration<br/>→ API permissions<br/>→ OAuth2 flows"]
    MC --> IP2["Intune Config Profiles<br/>Settings Catalog<br/>Security Baselines"]
    MS --> AP2["Azure Policy assignments<br/>Arc extensions<br/>OrgPath ARM tag"]

    classDef plane fill:#e8f4f8,stroke:#2980b9,stroke-width:2px,font-weight:bold
    classDef target fill:#eafaea,stroke:#27ae60,stroke-width:1px
    classDef note fill:#fefefe,stroke:#bdc3c7,stroke-width:1px,font-style:italic
    classDef root fill:#fdebd0,stroke:#e67e22,stroke-width:2px,font-weight:bold

    class ADC root
    class IP,WP,MP plane
    class ED,WI,MC,MS target
    class IP_note,WP_note note
    class OP,AP,IP2,AP2 note
