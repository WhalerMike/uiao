<!-- ===================================================================
     deploy/windows-server/web.config
     IIS HttpPlatformHandler configuration for UIAO AD Survey API
     Windows Server 2026 / IIS 10

     HttpPlatformHandler: starts Python as a child process and proxies
     HTTP traffic. The ASPNETCORE_PORT pattern is NOT used here —
     HttpPlatformHandler sets %HTTP_PLATFORM_PORT% which uvicorn binds to.
     =================================================================== -->
<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- HttpPlatformHandler — forwards all requests to Python/uvicorn -->
    <handlers>
      <add name="UIAOPythonHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <httpPlatform
        processPath="C:\srv\uiao\.venv\Scripts\python.exe"
        arguments="C:\inetpub\uiao-api\run.py"
        stdoutLogEnabled="true"
        stdoutLogFile="C:\Logs\uiao-api\python-%datetime%.log"
        startupTimeLimit="120"
        startupRetryCount="3"
        rapidFailsPerMinute="5"
        requestTimeout="00:05:00"
        forwardWindowsAuthToken="true">
      <!-- forwardWindowsAuthToken="true" passes the Windows token to Python
           so the authenticated user identity is available in the request. -->
      <environmentVariables>
        <!-- UIAO substrate root — must match machine env variable -->
        <environmentVariable name="UIAO_WORKSPACE_ROOT"
                             value="C:\srv\uiao" />
        <!-- Python will bind to this port; IIS proxies to it -->
        <environmentVariable name="UIAO_API_PORT"
                             value="%HTTP_PLATFORM_PORT%" />
        <!-- Set log level: INFO for production, DEBUG for troubleshooting -->
        <environmentVariable name="UIAO_LOG_LEVEL"
                             value="INFO" />
        <!-- Default AD server for health check ping -->
        <environmentVariable name="UIAO_AD_DEFAULT_SERVER"
                             value="dc01.corp.contoso.com" />
        <!-- Allowed host header values — comma-separated -->
        <environmentVariable name="UIAO_API_ALLOWED_HOSTS"
                             value="uiao-api.corp.contoso.com,localhost" />
        <!-- Entra credentials come from MACHINE-LEVEL env vars, not here.
             Never put secrets in web.config. -->
      </environmentVariables>
    </httpPlatform>

    <!-- ---------------------------------------------------------------
         Security: Windows Authentication only
         Anonymous disabled — every request must present Kerberos ticket
         --------------------------------------------------------------- -->
    <security>
      <authentication>
        <anonymousAuthentication enabled="false" />
        <windowsAuthentication enabled="true">
          <providers>
            <!-- Negotiate tries Kerberos first, falls back to NTLM.
                 For pure Kerberos: use <add value="Kerberos" /> only.
                 Negotiate is safer during pilot phase. -->
            <add value="Negotiate" />
            <add value="NTLM" />
          </providers>
        </windowsAuthentication>
        <basicAuthentication enabled="false" />
        <digestAuthentication enabled="false" />
      </authentication>
    </security>

    <!-- ---------------------------------------------------------------
         HTTPS redirect — ensure HTTP requests get redirected to HTTPS
         (IIS binding should be HTTPS-only; this is a belt-and-suspenders)
         --------------------------------------------------------------- -->
    <rewrite>
      <rules>
        <rule name="HTTP to HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect"
                  url="https://{HTTP_HOST}/{R:1}"
                  redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>

    <!-- ---------------------------------------------------------------
         Response headers — security hardening
         --------------------------------------------------------------- -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Strict-Transport-Security"
             value="max-age=31536000; includeSubDomains" />
        <!-- Remove IIS server version header -->
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

    <!-- Log to W3C extended format — important for auth audit trail -->
    <httpLogging dontLog="false" />

  </system.webServer>
</configuration>
