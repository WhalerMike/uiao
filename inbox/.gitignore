# inbox/ is a local processing scratch area. Binary inputs stay
# local; only README.md is tracked.

# Office documents
*.doc
*.docx
*.docm
*.dot
*.dotx

# Spreadsheets
*.xls
*.xlsx
*.xlsm
*.xlsb
*.csv

# Presentations
*.ppt
*.pptx
*.pptm

# PDF and other print-layout inputs
*.pdf

# Archives
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz

# Images (drop into docs/publications/series-assets/ for publishing)
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.svg

# Raw text exports — keep only if explicitly tracked
*.rtf
*.odt
*.ods
*.odp

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Explicit allow-list: the README is always tracked.
!README.md
!.gitignore
