  ],
  "impl_path": "impl/src/uiao/impl/adapters/modernization/gcc-boundary-probe/",
  "capabilities": {
    "intune_feature_probe": true,
    "arc_telemetry_probe": true,
    "gap_registry_generation": true,
    "compensating_control_mapping": true,
    "in_boundary_telemetry_aggregation": true,
    "wmi_device_health_collection": true,
    "ato_artifact_generation": true
  },
  "drift_classes_emitted": ["DRIFT-BOUNDARY"],
  "severity_range": ["P1", "P2", "P3"],
