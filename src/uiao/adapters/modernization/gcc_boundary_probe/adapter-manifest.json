  "vendor": "UIAO",
  "product": "GCC Boundary Probe",
  "version_range": ">=1.0",
  "fedramp_authorized": true,
  "fedramp_note": "Read-only probe against M365 GCC-Moderate Graph API and Azure ARM. No data written to external systems.",
  "uiao_doc_ref": "UIAO_GCC_001",
  "canon_refs": [
    "ADR-030",
    "Appendix_U_Multi_Cloud_Boundary_Model",
    "Appendix_M_Drift_Detection_Engine",
