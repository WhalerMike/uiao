    "graph_api": [
      "DeviceManagementManagedDevices.Read.All",
      "DeviceManagementConfiguration.Read.All",
      "Device.Read.All",
      "DeviceManagementServiceConfig.Read.All"
    ],
    "azure_arm": [
      "Reader (subscription level — for ARC probes)"
    ]
  },
  "known_gaps": [
    "Probe accuracy depends on network policy at collection point",
