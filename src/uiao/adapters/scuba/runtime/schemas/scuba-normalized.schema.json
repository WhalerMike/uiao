{
  "title": "UIAO Normalized SCuBA Result",
    "type": "object",
      "required": [
          "assessment_metadata",
              "tenant",
                  "scuba_raw",
                      "normalized",
                          "ksi_results"
                            ],
                              "properties": {
                                  "assessment_metadata": {
                                        "type": "object",
                                              "required": [
                                                      "assessment_date",
                                                              "tool_version",
                                                                      "collector_host",
                                                                              "collector_user",
                                                                                      "run_id"
                                                                                            ],
                                                                                                  "properties": {
                                                                                                          "assessment_date": { "type": "string", "format": "date-time" },
                                                                                                                  "tool_version": { "type": "string" },
                                                                                                                          "collector_host": { "type": "string" },
                                                                                                                                  "collector_user": { "type": "string" },
                                                                                                                                          "run_id": { "type": "string" }
                                                                                                                                                }
                                                                                                                                                    },
                                                                                                                                                        "tenant": {
                                                                                                                                                              "type": "object",
                                                                                                                                                                    "required": ["tenant_id"],
                                                                                                                                                                          "properties": {
                                                                                                                                                                                  "tenant_id": { "type": "string" },
                                                                                                                                                                                          "subscription_id": { "type": "string" }
                                                                                                                                                                                                }
                                                                                                                                                                                                    },
                                                                                                                                                                                                        "scuba_raw": {
                                                                                                                                                                                                              "type": "object",
                                                                                                                                                                                                                    "properties": {
                                                                                                                                                                                                                            "results_file": { "type": "string" },
                                                                                                                                                                                                                                    "settings_export_file": { "type": "string" },
                                                                                                                                                                                                                                            "action_plan_file": { "type": "string" }
                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                      },
                                                                                                                                                                                                                                                          "normalized": {
                                                                                                                                                                                                                                                                "type": "object",
                                                                                                                                                                                                                                                                      "required": ["fields"],
                                                                                                                                                                                                                                                                            "properties": {
                                                                                                                                                                                                                                                                                    "fields": {
                                                                                                                                                                                                                                                                                              "type": "object",
                                                                                                                                                                                                                                                                                                        "properties": {
                                                                                                                                                                                                                                                                                                                    "MFAEnabled": { "type": "boolean" },
                                                                                                                                                                                                                                                                                                                                "LegacyAuthEnabled": { "type": "boolean" },
                                                                                                                                                                                                                                                                                                                                            "AdminCount": { "type": "integer" },
                                                                                                                                                                                                                                                                                                                                                        "ExternalForwardingAllowed": { "type": "boolean" },
                                                                                                                                                                                                                                                                                                                                                                    "MailboxAuditingEnabled": { "type": "boolean" },
                                                                                                                                                                                                                                                                                                                                                                                "ExternalSharingEnabled": { "type": "boolean" },
                                                                                                                                                                                                                                                                                                                                                                                            "SafeLinksEnabled": { "type": "boolean" },
                                                                                                                                                                                                                                                                                                                                                                                                        "SafeAttachmentsEnabled": { "type": "boolean" },
                                                                                                                                                                                                                                                                                                                                                                                                                    "ConditionalAccessPoliciesCount": { "type": "integer" },
                                                                                                                                                                                                                                                                                                                                                                                                                                "DLPPoliciesCount": { "type": "integer" }
                                                                                                                                                                                                                                                                                                                                                                                                                                          },
                                                                                                                                                                                                                                                                                                                                                                                                                                                    "additionalProperties": true
                                                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                      },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "ksi_results": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "type": "array",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "items": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "type": "object",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "required": ["ksi_id", "status", "severity"],
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "properties": {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "ksi_id": { "type": "string" },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "status": { "type": "string", "enum": ["PASS", "WARN", "FAIL"] },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "details": { "type": "string" }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          }
