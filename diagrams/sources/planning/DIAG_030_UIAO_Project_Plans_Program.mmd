graph TD
    NEED["Capability Need<br/>Identified"]

    subgraph subgraph_proposal ["Proposal Phase"]
        PP_SCOPE["Scope<br/>Definition"]
        PP_CANON["Canon Impact<br/>Assessment"]
        PP_ADR["ADR Drafted<br/>(if doctrinal)"]
        PP_APPROVE["Steward<br/>Approval"]
        PP_SCOPE --> PP_CANON
        PP_CANON --> PP_ADR
        PP_ADR --> PP_APPROVE
    end

    subgraph subgraph_execution ["Execution Phase"]
        EX_BRANCH["Feature Branch<br/>Created"]
        EX_IMPLEMENT["Implementation<br/>& Testing"]
        EX_VALIDATE["CI Validation<br/>6 Gates"]
        EX_PR["PR Submitted<br/>& Reviewed"]
        EX_BRANCH --> EX_IMPLEMENT
        EX_IMPLEMENT --> EX_VALIDATE
        EX_VALIDATE --> EX_PR
    end

    subgraph subgraph_governance ["Governance Review"]
        GR_DRIFT["Drift Scan<br/>Verification"]
        GR_REGISTRY["Registry<br/>Update Check"]
        GR_PROVENANCE["Provenance<br/>Chain Validation"]
        GR_MERGE["Merge &<br/>Release Notes"]
        GR_DRIFT --> GR_REGISTRY
        GR_REGISTRY --> GR_PROVENANCE
        GR_PROVENANCE --> GR_MERGE
    end

    NEED --> PP_SCOPE
    PP_APPROVE --> EX_BRANCH
    EX_PR --> GR_DRIFT

    GR_MERGE --> DELIVERED["Capability<br/>Delivered"]

    GR_PROVENANCE -->|"Drift Found"| EX_IMPLEMENT

    NOTE_AGENCY["Note: Agency templates follow<br/>same flow with customization layer"]

    style NOTE_AGENCY fill:#fffbeb,stroke:#f59e0b,stroke-width:1px
    style NEED fill:#2563eb,color:#ffffff,stroke:#1e40af
    style DELIVERED fill:#059669,color:#ffffff,stroke:#047857
