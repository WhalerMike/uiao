graph TD
    CHANGE["Canon Change<br/>Proposed"]

    subgraph subgraph_proposal ["Proposal & ADR"]
        PR_ASSESS["Impact<br/>Assessment"]
        PR_ADR["ADR Drafted<br/>Decision Recorded"]
        PR_REVIEW["Canon Steward<br/>Review"]
        PR_ASSESS --> PR_ADR
        PR_ADR --> PR_REVIEW
    end

    subgraph subgraph_ci_gates ["CI Enforcement Gates"]
        CI_META["metadata-validator<br/>Frontmatter Schema"]
        CI_DRIFT["drift-scan<br/>Provenance Check"]
        CI_APPEND["appendix-sync<br/>Index Integrity"]
        CI_DASH["dashboard-export<br/>Schema Readiness"]
        CI_LINK["link-check<br/>Reference Integrity"]
        CI_SBOM["sbom-audit<br/>Dependency Scan"]
        CI_META --> CI_DRIFT
        CI_DRIFT --> CI_APPEND
        CI_APPEND --> CI_DASH
        CI_DASH --> CI_LINK
        CI_LINK --> CI_SBOM
    end

    subgraph subgraph_merge ["Merge & Publish"]
        MG_SQUASH["Squash Merge<br/>to main"]
        MG_REGISTRY["Registry<br/>Auto-Update"]
        MG_DEPLOY["Docs Site<br/>Rebuild"]
        MG_SQUASH --> MG_REGISTRY
        MG_REGISTRY --> MG_DEPLOY
    end

    CHANGE --> PR_ASSESS
    PR_REVIEW --> CI_META
    CI_SBOM --> MG_SQUASH

    MG_DEPLOY --> CANON["Canon<br/>Updated"]

    CI_DRIFT -->|"DRIFT-PROVENANCE"| PR_ASSESS

    NOTE_BLOCK["Note: All 6 gates are<br/>CI-blocking on every PR"]

    style NOTE_BLOCK fill:#fffbeb,stroke:#f59e0b,stroke-width:1px
    style CHANGE fill:#2563eb,color:#ffffff,stroke:#1e40af
    style CANON fill:#059669,color:#ffffff,stroke:#047857
