graph TD
    INTAKE["Trainee Intake<br/>Role & Clearance Verification"]

    subgraph subgraph_curriculum ["Curriculum Mapping"]
        CM_ROLE["Role-Based<br/>Track Selection"]
        CM_PREREQ["Prerequisite<br/>Assessment"]
        CM_PATH["Learning Path<br/>Generation"]
        CM_ROLE --> CM_PREREQ
        CM_PREREQ --> CM_PATH
    end

    subgraph subgraph_delivery ["Content Delivery"]
        DL_CANON["Canonical Artifact<br/>Walkthrough"]
        DL_HANDS["Hands-On Lab:<br/>Governance Workflows"]
        DL_DRIFT["Drift Detection<br/>Simulation"]
        DL_REMED["Remediation<br/>Exercise"]
        DL_CANON --> DL_HANDS
        DL_HANDS --> DL_DRIFT
        DL_DRIFT --> DL_REMED
    end

    subgraph subgraph_assessment ["Assessment & Certification"]
        AS_QUIZ["Knowledge<br/>Assessment"]
        AS_PRACT["Practical<br/>Evaluation"]
        AS_REVIEW["Peer Review<br/>& Feedback"]
        AS_CERT["Certification<br/>Issuance"]
        AS_QUIZ --> AS_PRACT
        AS_PRACT --> AS_REVIEW
        AS_REVIEW --> AS_CERT
    end

    INTAKE --> CM_ROLE
    CM_PATH --> DL_CANON
    DL_REMED --> AS_QUIZ

    AS_CERT --> COMPLETE["Training Complete<br/>Role Activated"]

    %% Feedback loop
    AS_REVIEW -->|"Gaps Identified"| CM_PATH

    %% Annotations
    NOTE_GOV["Note: All training content<br/>traces to canonical artifacts"]
    NOTE_SLA["Note: Certification SLA<br/>tracked per governance rules"]

    style NOTE_GOV fill:#fffbeb,stroke:#f59e0b,stroke-width:1px
    style NOTE_SLA fill:#fffbeb,stroke:#f59e0b,stroke-width:1px
    style INTAKE fill:#2563eb,color:#ffffff,stroke:#1e40af
    style COMPLETE fill:#059669,color:#ffffff,stroke:#047857
