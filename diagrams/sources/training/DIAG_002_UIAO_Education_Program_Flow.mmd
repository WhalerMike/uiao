graph TD
    ENTRY["Agency Intake<br/>Mission Assessment"]

    subgraph subgraph_narrative ["Narrative Engagement"]
        NR_COMIC["Comic Series<br/>Introduction"]
        NR_CONCEPT["Concept Mapping<br/>UIAO to Agency Context"]
        NR_ASSESS["Comprehension<br/>Check"]
        NR_COMIC --> NR_CONCEPT
        NR_CONCEPT --> NR_ASSESS
    end

    subgraph subgraph_workshop ["Workshop Delivery"]
        WS_SETUP["Environment<br/>Provisioning"]
        WS_WALK["Substrate Walker<br/>Live Demo"]
        WS_DRIFT["Drift Detection<br/>Exercise"]
        WS_REMED["Remediation<br/>Walkthrough"]
        WS_SETUP --> WS_WALK
        WS_WALK --> WS_DRIFT
        WS_DRIFT --> WS_REMED
    end

    subgraph subgraph_cert ["Certification"]
        CT_EVAL["Practical<br/>Evaluation"]
        CT_REVIEW["Peer Review"]
        CT_ISSUE["Certificate<br/>Issuance"]
        CT_EVAL --> CT_REVIEW
        CT_REVIEW --> CT_ISSUE
    end

    ENTRY --> NR_COMIC
    NR_ASSESS --> WS_SETUP
    WS_REMED --> CT_EVAL

    CT_ISSUE --> COMPLETE["Operator<br/>Certified"]

    CT_REVIEW -->|"Gaps Found"| WS_DRIFT

    NOTE_SRC["Note: All materials trace<br/>to canonical artifacts"]

