graph TD
    EVENT["Compliance<br/>Event Received"]

    subgraph subgraph_evaluation ["Policy Evaluation"]
        PE_LOAD["EPL Rule<br/>Loading"]
        PE_MATCH["Evidence<br/>Pattern Match"]
        PE_EVAL["Rule<br/>Evaluation"]
        PE_DECIDE["Decision<br/>Rendering"]
        PE_LOAD --> PE_MATCH
        PE_MATCH --> PE_EVAL
        PE_EVAL --> PE_DECIDE
    end

    subgraph subgraph_action ["Action Dispatch"]
        AD_ROUTE["Action<br/>Routing"]
        AD_EXEC["Enforcement<br/>Execution"]
        AD_VERIFY["Result<br/>Verification"]
        AD_RECORD["Audit Trail<br/>Recording"]
        AD_ROUTE --> AD_EXEC
        AD_EXEC --> AD_VERIFY
        AD_VERIFY --> AD_RECORD
    end

    subgraph subgraph_zero_trust ["Zero-Trust Gate"]
        ZT_IDENTITY["Identity<br/>Verification"]
        ZT_CONTEXT["Context<br/>Evaluation"]
        ZT_AUTHORIZE["Authorization<br/>Decision"]
        ZT_IDENTITY --> ZT_CONTEXT
        ZT_CONTEXT --> ZT_AUTHORIZE
    end

    EVENT --> ZT_IDENTITY
    ZT_AUTHORIZE --> PE_LOAD
    PE_DECIDE --> AD_ROUTE

    AD_RECORD --> ENFORCED["Policy<br/>Enforced"]

    PE_DECIDE -->|"Deny"| BLOCK["Action<br/>Blocked"]
    AD_VERIFY -->|"Failed"| PE_EVAL

    NOTE_EPL["Note: EPL policies are<br/>canon-governed artifacts"]

    style NOTE_EPL fill:#fffbeb,stroke:#f59e0b,stroke-width:1px
    style EVENT fill:#2563eb,color:#ffffff,stroke:#1e40af
    style ENFORCED fill:#059669,color:#ffffff,stroke:#047857
    style BLOCK fill:#dc2626,color:#ffffff,stroke:#991b1b
