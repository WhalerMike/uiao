graph TD
    FAILURE["Failure<br/>Detected"]

    subgraph subgraph_detection ["Detection & Classification"]
        DT_TYPE["Failure Type<br/>Classification"]
        DT_SCOPE["Impact Scope<br/>Assessment"]
        DT_NOTIFY["Stakeholder<br/>Notification"]
        DT_TYPE --> DT_SCOPE
        DT_SCOPE --> DT_NOTIFY
    end

    subgraph subgraph_failover ["Failover Execution"]
        FO_PASSIVE["Activate<br/>Passive Node"]
        FO_DNS["DNS/Routing<br/>Cutover"]
        FO_VERIFY["Service<br/>Health Verify"]
        FO_PASSIVE --> FO_DNS
        FO_DNS --> FO_VERIFY
    end

    subgraph subgraph_reconcile ["State Reconciliation"]
        RC_SYNC["Data<br/>Sync Check"]
        RC_DRIFT["Drift<br/>Assessment"]
        RC_REPAIR["State<br/>Repair"]
        RC_VALIDATE["Consistency<br/>Validation"]
        RC_SYNC --> RC_DRIFT
        RC_DRIFT --> RC_REPAIR
        RC_REPAIR --> RC_VALIDATE
    end

    FAILURE --> DT_TYPE
    DT_NOTIFY --> FO_PASSIVE
    FO_VERIFY --> RC_SYNC

    RC_VALIDATE --> RESTORED["Service<br/>Restored"]

    FO_VERIFY -->|"Health Fail"| DT_TYPE

    NOTE_HA["Note: Active-passive replication<br/>per governance architecture"]

    style NOTE_HA fill:#fffbeb,stroke:#f59e0b,stroke-width:1px
    style FAILURE fill:#dc2626,color:#ffffff,stroke:#991b1b
    style RESTORED fill:#059669,color:#ffffff,stroke:#047857
