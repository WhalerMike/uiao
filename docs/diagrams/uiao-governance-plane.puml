@startuml UIAO_Governance_Plane
' Appendix E — Governance Plane Cross-Dependency Diagram

skinparam backgroundColor #FEFEFE
skinparam componentBackgroundColor #EDE7F6
skinparam componentBorderColor #4527A0
skinparam componentFontSize 12
skinparam arrowColor #2C3E50

title **Appendix E — Governance Plane**\n//Internal & Cross-Plane Dependencies//

component "E-01\nARB\nCoordination" as E01 {
  note right : MISSING — No ADR\nyet assigned
}

component "E-02\nMission-Partner\nCorridors" as E02 {
  portin "ADR-018" as a018
}

component "E-03\nCross-Fabric\nConsistency" as E03 {
  note right : MISSING — No ADR\nyet assigned
}

' Internal dependencies [NEW (Proposed)]
E01 --> E03 : ARB decisions\nenforce consistency
E02 --> E03 : corridor rules\nfeed consistency

' Cross-plane — E-01 ARB governs all families [NEW (Proposed)]
component "A-01 Adapter\nLifecycle" as A01 #E8F0FE
component "A-03 Hot-Swap\n& Rollback" as A03 #E8F0FE
component "B-02 Identity\nAnchoring" as B02 #E8F8E8
component "B-03 Multi-Cloud\nIdentity" as B03 #E8F8E8

A01 ..> E01 : ARB gate
A03 ..> E01 : ARB gate
B02 ..> E02 : identity ->\ncorridors
B03 ..> E02 : multi-cloud ->\ncorridors

' E-03 consistency gates all families [NEW (Proposed)]
component "All Fabric\nEntry Points" as ALL #F5F5F5
E03 ..> ALL : cross-fabric\nconsistency gate

note bottom
  Governance Plane is the oversight layer.
  E-01 and E-03 need ADR assignments (MISSING).
  Commercial Cloud | FedRAMP governed | Not FedRAMP High.
  Amazon Connect Contact Center: Commercial Cloud exception.
end note

@enduml
