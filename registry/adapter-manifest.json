{
  "adapter_id": "active-directory-survey-v1",
  "adapter_type": "modernization",
  "mission_class": "identity",
  "class": "modernization",
  "vendor": "Microsoft",
  "product": "Active Directory",
  "version_range": ">=2008R2",
  "fedramp_authorized": false,
  "fedramp_note": "On-premises source; not a FedRAMP service. Target (Entra ID) is FedRAMP Moderate.",
  "uiao_doc_ref": "UIAO_AD_001",
  "canon_ref": "Appendix_F_Phase1_Phase2",
  "capabilities": {
    "ou_intent_classification": true,
    "sites_services_audit": true,
    "gpo_archaeology": true,
    "service_account_inventory": true,
    "computer_object_survey": true,
    "orgpath_assignment": true,
    "orgpath_writeback": true,
    "sync_enrichment_validation": true,
    "forest_trust_inventory": true,
    "identity_collision_detection": true
  },
  "read_only_modes": ["survey", "dry-run"],
  "write_modes": ["orgpath-writeback"],
  "required_ad_permissions": [
    "Domain Users (read)",
    "Read all user attributes",
    "Read all OU attributes",
    "Read Group Policy Objects",
    "Read Sites and Services",
    "Read computer objects"
  ],
  "required_entra_permissions": [
    "User.Read.All",
    "User.ReadWrite.All (writeback mode only)",
    "Group.Read.All"
  ],
  "drift_classes_emitted": [
    "DRIFT-IDENTITY",
    "DRIFT-SCHEMA",
    "DRIFT-PROVENANCE",
    "DRIFT-SEMANTIC"
  ],
  "gov_error_codes_used": [
    "GOV-MIG-001",
    "GOV-MIG-002",
    "GOV-MIG-003",
    "GOV-MIG-004",
    "GOV-MIG-005",
    "GOV-DRF-001",
    "GOV-DRF-003",
    "GOV-SCH-001",
    "GOV-SCH-003"
  ],
  "known_gaps": [
    "Does not enumerate ADCS certificate templates directly; see pki-adapter",
    "Does not resolve RADIUS/NPS service accounts; see radius-adapter",
    "Does not handle cross-forest trust resolution; see trust-inventory-adapter (planned)"
  ],
  "phase_map": {
    "F1_discovery":   "survey.py::run_discovery()",
    "F2_orgpath_map": "orgpath.py::build_ou_mapping()",
    "F3_writeback":   "orgpath.py::write_orgpath_to_ad()"
  }
}
