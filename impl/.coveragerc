[run]
source = src/uiao_core
omit =
    src/uiao_core/generators/briefing.py
    src/uiao_core/generators/rich_docx.py
    src/uiao_core/generators/pptx.py
    src/uiao_core/generators/sbom.py
    src/uiao_core/generators/gemini_visuals.py
    src/uiao_core/generators/plantuml.py
    src/uiao_core/onboarding/wizard.py
    src/uiao_core/onboarding/validator.py

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
