{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://uiao.gov/schemas/udc/udc_export.schema.json",
  "title": "UDC Export Schema",
  "description": "JSON Schema for validating UDC export configurations",
  "type": "object",
  "required": ["export_config"],
  "properties": {
    "export_config": {
      "type": "object",
      "required": ["formats", "export_dir"],
      "properties": {
        "formats": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["format", "enabled", "tool"],
            "properties": {
              "format": {
                "type": "string",
                "enum": ["docx", "pdf", "pptx", "xlsx", "md", "html"]
              },
              "description": { "type": "string" },
              "enabled": { "type": "boolean" },
              "tool": { "type": "string" }
            }
          }
        },
        "naming_convention": {
          "type": "object",
          "properties": {
            "pattern": { "type": "string" },
            "sanitize": { "type": "boolean" },
            "lowercase": { "type": "boolean" },
            "replace_spaces": { "type": "string" }
          }
        },
        "export_dir": { "type": "string" },
        "integrity": {
          "type": "object",
          "properties": {
            "hash_algorithm": { "type": "string", "enum": ["sha256", "sha512"] },
            "generate_manifest": { "type": "boolean" },
            "manifest_file": { "type": "string" },
            "immutable": { "type": "boolean" },
            "verify_on_read": { "type": "boolean" }
          }
        },
        "artifact_upload": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "retention_days": { "type": "integer" },
            "compress": { "type": "boolean" },
            "compression_format": { "type": "string" }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
