{
  "$comment": "Crosswalk Index Schema — matches canon/data/crosswalk-index.yml.",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UIAO Crosswalk Index Schema",
  "description": "Schema for validating the top-level crosswalk index document that links control planes to architecture, project plans, canon volumes, and modernization appendices.",
  "type": "object",
  "required": ["crosswalk", "plane_crosswalk"],
  "additionalProperties": true,
  "properties": {
    "crosswalk": {
      "type": "object",
      "required": ["version", "date", "purpose"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
        },
        "date": {
          "type": "string",
          "pattern": "^[0-9]{4}(-[0-9]{2}){0,2}$"
        },
        "purpose": { "type": "string", "minLength": 1 },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "plane_crosswalk": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "control_plane_spec"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "name": { "type": "string", "minLength": 1 },
          "control_plane_spec": { "type": "string", "minLength": 1 },
          "architecture_diagram": { "type": "string" },
          "project_plans": {
            "type": "array",
            "items": { "type": "string" }
          },
          "canon_volumes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "modernization_appendix": { "type": "string" },
          "diagrams": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "cross_plane_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["planes", "description"],
        "properties": {
          "planes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
