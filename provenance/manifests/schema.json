{
  "title": "UIAO Provenance Manifest",
  "type": "object",
  "required": [
    "manifest_id",
    "generated_at",
    "adapter_version",
    "ruleset_version",
    "source_files",
    "hashes",
    "lineage",
    "environment"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "description": "Unique ID for this provenance manifest."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "adapter_version": {
      "type": "string"
    },
    "ruleset_version": {
      "type": "string"
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "lineage": {
      "type": "object",
      "properties": {
        "scuba_run_id": { "type": "string" },
        "normalization_id": { "type": "string" },
        "ksi_evaluation_id": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "user": { "type": "string" },
        "os_version": { "type": "string" },
        "powershell_version": { "type": "string" }
      }
    }
  }
}
