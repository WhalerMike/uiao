# Repo-root Git attributes.
#
# LFS routing for binary image assets produced by the Gemini pipeline
# (docs/generate_images.py). PNGs under the customer-documents tree and
# the canonical shared-image directory can accumulate hundreds of MB
# over many releases — LFS keeps git history light and clones fast.
#
# Per-file LFS filter: content stored in LFS, pointers stored in git.
# Binary media: never diff, never merge.
# Text normalization: line endings enforced to LF.

# ─── LFS-tracked binary media ────────────────────────────────────────
docs/customer-documents/**/images/*.png          filter=lfs diff=lfs merge=lfs -text
docs/customer-documents/**/images/*.webp         filter=lfs diff=lfs merge=lfs -text
docs/customer-documents/**/images/*.jpg          filter=lfs diff=lfs merge=lfs -text
docs/customer-documents/**/images/*.jpeg         filter=lfs diff=lfs merge=lfs -text
docs/images/canonical/*.png                      filter=lfs diff=lfs merge=lfs -text
docs/images/canonical/*.webp                     filter=lfs diff=lfs merge=lfs -text

# Sidecar JSON (prompt hash + generation metadata) stays in git as text
# so diffs over time show provenance changes.
docs/customer-documents/**/images/*.png.json     text eol=lf
docs/images/canonical/*.png.json                 text eol=lf

# ─── Baseline text normalization ────────────────────────────────────
* text=auto eol=lf
*.md   text eol=lf
*.qmd  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.py   text eol=lf
*.ps1  text eol=lf
*.toml text eol=lf
*.sh   text eol=lf
