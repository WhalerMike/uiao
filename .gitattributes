# Repo-root Git attributes.
#
# Binary image assets produced by the Gemini pipeline (scripts/generate_images.py)
# live as plain git blobs. LFS was retired here in favor of a flat git store —
# repo size grew ~100 MB but CI no longer burns LFS bandwidth on every render.
# If asset growth becomes unmanageable, the next step is external object
# storage (S3/R2) rather than re-introducing LFS.
#
# Binary media: never diff, never merge.
# Text normalization: line endings enforced to LF.

# ─── Binary media (plain git blobs) ──────────────────────────────────
docs/customer-documents/**/images/*.png          binary
docs/customer-documents/**/images/*.webp         binary
docs/customer-documents/**/images/*.jpg          binary
docs/customer-documents/**/images/*.jpeg         binary
docs/images/canonical/*.png                      binary
docs/images/canonical/*.webp                     binary

# Sidecar JSON (prompt hash + generation metadata) stays in git as text
# so diffs over time show provenance changes.
docs/customer-documents/**/images/*.png.json     text eol=lf
docs/images/canonical/*.png.json                 text eol=lf

# ─── Baseline text normalization ────────────────────────────────────
* text=auto eol=lf
*.md   text eol=lf
*.qmd  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.py   text eol=lf
*.ps1  text eol=lf
*.toml text eol=lf
*.sh   text eol=lf
*.ps1 text eol=lf
