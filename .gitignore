# ============================================
# UIAO Canonical .gitignore
# Prevents drift, export contamination, and noise
# ============================================

# --- Generated Documents (never commit) ---
*.docx
*.pptx
*.pdf
*.html
*.csv

# --- Quarto Outputs ---
/_site/
/docs/*.html
*.qmd

# --- Export Directories ---
exports/
exports/**

# --- Rendered Diagrams ---
*.png.rendered
*.svg.rendered

# --- Temporary / Local Files ---
~$*
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db

# --- Python / Build Artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# --- Node / JS (if ever used) ---
node_modules/

# --- VSCode / IDE ---
.vscode/
.idea/

# --- Logs ---
*.log

# --- PlantUML JAR (local tool, not committed) ---
plantuml.jar
tools/plantuml.jar
tools/plantuml/plantuml.jar

# Ignore Claude artifacts
.claude/

.claude/
.claude/
.claude/

# Phase D Stage 1 additions
dryrun-output/
build/
*.egg-info/
pytest-results.txt
refresh_actions.json
_output/
.pytest_cache/
.coverage

# Phase D Stage 3 additions — doc pipeline now lives in uiao-docs
_quarto.yml
docs/
templates/
generation-inputs/
visuals/
assets/
exports/
plantuml.jar
