# Python build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
src/uiao.egg-info/
build/
dist/
*.whl
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Generated artifacts (written by uiao generate-* commands)
exports/

# Image pipeline manifest — deterministic aggregation rebuilt on every
# `python scripts/generate_images.py` run. Not source; rebuild with
# `--scan-only` whenever needed.
docs/images/.image-manifest.json

# Corpus index — generated by docs/scripts/update_corpus_index.js and
# regenerated by the Update Corpus Index workflow (in the docs subrepo)
# on push to main. Path is relative to monorepo root; in the docs subrepo
# the same artifact lives at docs/_data/corpus-index.json.
docs/docs/_data/corpus-index.json

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Quarto
_site/
_freeze/
.quarto/

# OS / misc
*.log
*.tmp
.claude/

# Windows shell mishap — `git lfs install` (or similar) invoked with
# `/dev/null` as a path on Windows creates this directory in the worktree
# instead of redirecting to the null device. The real LFS hooks live in
# .git/hooks/ per core.hookspath.
dev/null/

# Audit input scratch — source files copied from OneDrive for agent review.
# Not for commit; archive/delete when audit complete.
/inbox/_audit-input/

/.quarto/
**/*.quarto_ipynb

doc-audit*.csv
