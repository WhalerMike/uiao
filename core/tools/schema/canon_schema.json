{
  "$comment": "Canon Document Metadata Schema — matches YAML frontmatter of files under canon/.",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UIAO Canon Document Metadata Schema",
  "description": "Schema for validating YAML frontmatter on canonical UIAO documents in canon/ (including canon/specs/).",
  "type": "object",
  "required": [
    "document_id",
    "title",
    "version",
    "status",
    "classification",
    "owner",
    "created_at",
    "updated_at",
    "boundary"
  ],
  "additionalProperties": true,
  "properties": {
    "document_id": {
      "type": "string",
      "pattern": "^UIAO_[0-9]{3}$",
      "description": "Canonical document identifier (UIAO_NNN). Reserved ranges are documented in canon/document-registry.yaml."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
      "description": "Semantic-ish version, X.Y or X.Y.Z."
    },
    "status": {
      "type": "string",
      "enum": ["Current", "Draft", "Deprecated", "Archived", "Superseded"]
    },
    "classification": {
      "type": "string",
      "enum": ["CANONICAL", "DERIVED", "INTERNAL", "PUBLIC"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "boundary": {
      "type": "string",
      "enum": ["GCC-Moderate", "GCC-High", "Commercial", "DoD"]
    },
    "author": {
      "type": "string"
    },
    "no_hallucination_mode": {
      "type": "string",
      "enum": ["ENABLED", "DISABLED"]
    },
    "nhp": {
      "type": "boolean"
    },
    "provenance": {
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "version": { "type": "string" },
        "derived_at": { "type": "string" },
        "derived_by": { "type": "string" }
      }
    },
    "control_planes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Identity", "Network", "Addressing", "Telemetry", "Security", "Management"]
      }
    }
  }
}
