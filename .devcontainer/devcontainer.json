{
  "name": "UIAO monorepo",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/quarto-dev/quarto-cli/devcontainers-features:1": {
      "version": "latest"
    }
  },
  "postCreateCommand": "bash scripts/bootstrap.sh",
  "containerEnv": {
    "UIAO_WORKSPACE_ROOT": "${containerWorkspaceFolder}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "quarto.quarto",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "github.vscode-github-actions"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["impl/tests"],
        "ruff.configuration": "impl/pyproject.toml",
        "files.associations": {
          "*.qmd": "markdown"
        }
      }
    }
  },
  "mounts": [],
  "remoteUser": "vscode",
  "forwardPorts": [],
  "portsAttributes": {}
}
